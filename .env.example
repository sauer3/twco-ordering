# Copy this file to .env and fill in your real values.
# The .env file is gitignored and will not be committed.

VINOSMITH_TOKEN=paste-your-token-here

# ---- Email settings (only needed for the weekly scheduled report) ----------
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER is the full
# address, and SMTP_PASSWORD is a Google "App Password" (NOT your normal
# password) -- create one at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=youraddress@gmail.com
# Comma-separated list of recipients (husband + business partner):
EMAIL_TO=husband@example.com, partner@example.com
